# Mattar frontend build-time — copy to .env before npm run build

VITE_API_BASE_URL=http://localhost:3000
VITE_COGNITO_USER_POOL_ID=your-cognito-user-pool-id
VITE_COGNITO_CLIENT_ID=your-cognito-app-client-id
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback
